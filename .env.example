# ==============================================================================
# WebGIS Potensi Desa Rambipuji — Environment Configuration Example
# Copy this file to .env and adjust values for your environment
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL / PostGIS Database Configuration
# ------------------------------------------------------------------------------
POSTGRES_DB=rambipuji_gis
POSTGRES_USER=rambipuji_user
POSTGRES_PASSWORD=rambipuji_secret_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Django Backend Configuration
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-rambipuji-gis
DJANGO_DEBUG=True

# Development:
# ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
# Production (tambahkan domain VPS):
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,rambipuji.research-ai.my.id

# Development:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost
# Production (tambahkan domain VPS):
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,https://rambipuji.research-ai.my.id

# JWT Authentication Secret & Token Expiry (in hours)
JWT_SECRET_KEY=jwt-secret-key-change-me-in-production
JWT_EXPIRATION_HOURS=24

# ------------------------------------------------------------------------------
# GeoServer GIS Server Configuration
# ------------------------------------------------------------------------------
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=rambipuji

# Internal Docker GeoServer URL (accessed by backend/nginx, JANGAN diubah)
INTERNAL_GEOSERVER_URL=http://geoserver:8080/geoserver

# ------------------------------------------------------------------------------
# Next.js Frontend Configuration
# ------------------------------------------------------------------------------
# ⚠️  NEXT_PUBLIC_* di-bake ke JS bundle saat BUILD TIME, bukan runtime.
#     Setiap kali nilai ini diubah, frontend WAJIB di-rebuild ulang:
#       docker compose -p rambipuji -f docker-compose.yml -f docker-compose.prod.yml \
#         build --no-cache frontend
#       docker compose -p rambipuji -f docker-compose.yml -f docker-compose.prod.yml \
#         up -d --force-recreate frontend

# Development (akses via nginx lokal port 8888):
# NEXT_PUBLIC_API_URL=http://localhost:8888/api
# NEXT_PUBLIC_GEOSERVER_URL=http://localhost:8888/geoserver
# PUBLIC_BASE_URL=http://localhost:8888

# Production (ganti dengan domain VPS yang sebenarnya):
NEXT_PUBLIC_API_URL=https://rambipuji.research-ai.my.id/api
NEXT_PUBLIC_GEOSERVER_URL=https://rambipuji.research-ai.my.id/geoserver
PUBLIC_BASE_URL=https://rambipuji.research-ai.my.id

# Internal Docker URL (dipakai Next.js SSR server-side, JANGAN diubah)
INTERNAL_API_URL=http://backend:8000/api
